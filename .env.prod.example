# ═══════════════════════════════════════════════════════════════════════════
# 48ID Production Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# ⚠️  SECURITY WARNING: Never commit this file with real credentials!
# Store production secrets in a secure secret manager (AWS Secrets Manager,
# HashiCorp Vault, Azure Key Vault, etc.)
# ═══════════════════════════════════════════════════════════════════════════

# ── Spring Profile ──
SPRING_PROFILES_ACTIVE=prod

# ── Database (PostgreSQL) ──
# Use managed database service (AWS RDS, Cloud SQL, Azure Database)
DATABASE_URL=jdbc:postgresql://prod-db.example.com:5432/fortyeightid
DATABASE_USERNAME=fortyeightid_prod
DATABASE_PASSWORD=<CHANGE_ME_STRONG_PASSWORD>

# ── Redis ──
# Use managed Redis service (ElastiCache, Cloud Memorystore, Azure Cache)
REDIS_HOST=prod-redis.example.com
REDIS_PORT=6379
REDIS_PASSWORD=<CHANGE_ME_REDIS_PASSWORD>
REDIS_SSL=true
REDIS_CLUSTER_ENABLED=true
REDIS_TIMEOUT=5000

# ── Mail (Production) ──
# Use transactional email service (SendGrid, AWS SES, Mailgun)
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=<CHANGE_ME_SENDGRID_API_KEY>
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=no-reply@k48.io
MAIL_LOGIN_URL=https://app.k48.io/login
MAIL_ACTIVATION_URL=https://app.k48.io/activate-account
MAIL_RESET_PASSWORD_URL=https://app.k48.io/reset-password

# ── JWT / Security ──
# Generate production RSA keys and store in secret manager
# See: docs/guide/deployment.md#generate-rsa-keys
JWT_ISSUER=https://id.k48.io
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=86400
JWT_RSA_PUBLIC_KEY=<CHANGE_ME_BASE64_ENCODED_PUBLIC_KEY>
JWT_RSA_PRIVATE_KEY=<CHANGE_ME_BASE64_ENCODED_PRIVATE_KEY>

# ── CORS ──
# Comma-separated list of production origins
CORS_ALLOWED_ORIGINS=https://hub.k48.io,https://lp.k48.io,https://admin.k48.io

# ── Server ──
SERVER_PORT=8080
API_PREFIX=/api/v1

# ── OpenAPI / Swagger ──
# Disable Swagger UI in production for security
SPRINGDOC_SWAGGER_ENABLED=false
OPENAPI_SERVERS=https://id.k48.io

# ── Rate Limiting (Production - Strict) ──
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW=900
RATE_LIMIT_FORGOT_PASSWORD_ATTEMPTS=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=3600
RATE_LIMIT_GLOBAL_PER_IP=100

# ── Database Connection Pool (Production) ──
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=5
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=30000
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=600000
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=1800000

# ── Logging (Production) ──
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_IO_K48_FORTYEIGHTID=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_SECURITY=WARN

# ── Actuator (Production) ──
# Expose only health and info endpoints
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never
