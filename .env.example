# ═══════════════════════════════════════════════════════════════════════════
# 48ID Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# 
# Quick Start:
#   1. Copy this file: cp .env.example .env
#   2. Choose your environment profile below
#   3. Start services: docker compose up -d db redis mailpit
#   4. Run application: ./gradlew bootRun
#
# Environment Profiles:
#   dev  = Development (detailed logs, Swagger enabled, relaxed security)
#   test = Testing/CI (in-memory services, mocked email)
#   prod = Production (strict security, no Swagger, requires HTTPS)
# ═══════════════════════════════════════════════════════════════════════════

# ── Environment Profile ──
SPRING_PROFILES_ACTIVE=dev

# ── Database (PostgreSQL) ──
# Dev: Uses docker-compose service 'db' on port 5433
# Test: Uses Testcontainers (automatic)
# Prod: Use managed database (RDS, Cloud SQL, etc.)
DATABASE_URL=jdbc:postgresql://localhost:5433/fortyeightid
DATABASE_USERNAME=fortyeightid
DATABASE_PASSWORD=fortyeightid
DATABASE_NAME=fortyeightid
DATABASE_HOST_PORT=5433

# ── Redis (Session & Rate Limiting) ──
# Dev: Uses docker-compose service 'redis'
# Test: Uses embedded/test Redis
# Prod: Use managed Redis (ElastiCache, Cloud Memorystore, etc.)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email Service ──
# Dev: Use Mailpit (docker compose up -d mailpit) - Web UI: http://localhost:8025
# Test: Mock email service (no real emails sent)
# Prod: Use real SMTP (Gmail, SendGrid, AWS SES, etc.)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@48id.local

# ── Frontend URLs (for email links) ──
# Dev: Local frontend server
# Prod: Your production domain
MAIL_LOGIN_URL=http://localhost:3000/login
MAIL_ACTIVATION_URL=http://localhost:3000/activate-account
MAIL_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ── Mailpit (Development Email Testing) ──
# Web UI port for viewing emails in development
MAILPIT_UI_PORT=8025

# ── JWT Configuration ──
# Issuer should match your backend URL
JWT_ISSUER=http://localhost:8080
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=86400

# RSA Keys for JWT signing
# Dev: Use provided keys in src/main/resources/keys/
# Prod: Generate new keys and store securely
JWT_RSA_PUBLIC_KEY=classpath:keys/public.pem
JWT_RSA_PRIVATE_KEY=classpath:keys/private.pem

# ── CORS (Cross-Origin Resource Sharing) ──
# Dev: Allow localhost frontend
# Prod: Set to your frontend domain(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Server Configuration ──
SERVER_PORT=8080
API_PREFIX=/api/v1

# ── API Documentation (Swagger) ──
# Dev/Test: true (access at http://localhost:8080/api/v1/docs)
# Prod: false (disable in production for security)
SPRINGDOC_SWAGGER_ENABLED=true
OPENAPI_SERVERS=http://localhost:8080

# ═══════════════════════════════════════════════════════════════════════════
# Environment-Specific Examples:
# ═══════════════════════════════════════════════════════════════════════════
#
# For Production (.env.prod):
# SPRING_PROFILES_ACTIVE=prod
# DATABASE_URL=jdbc:postgresql://prod-db.example.com:5432/fortyeightid
# DATABASE_USERNAME=prod_user
# DATABASE_PASSWORD=secure_password
# REDIS_HOST=prod-redis.example.com
# REDIS_PASSWORD=redis_password
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=your_sendgrid_api_key
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
# MAIL_FROM=no-reply@yourdomain.com
# JWT_ISSUER=https://id.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com
# SPRINGDOC_SWAGGER_ENABLED=false
# OPENAPI_SERVERS=https://id.yourdomain.com
#
# For Testing (.env.test):
# SPRING_PROFILES_ACTIVE=test
# (Most values will use application-test.properties defaults)
# ═══════════════════════════════════════════════════════════════════════════