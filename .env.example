# ═══════════════════════════════════════════════════════════════════════════
# 48ID Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Quick Start (Local Development):
#   1. Copy this file: cp .env.example .env
#   2. Start services: docker compose up -d postgres redis mailpit
#   3. Run application: ./gradlew bootRun
#
# For Production:
#   - Change SPRING_PROFILES_ACTIVE to "prod"
#   - Update DATABASE_* with production credentials
#   - Configure real MAIL_* settings
#   - Set strong passwords and use secret managers
#   - Generate production RSA keys (see docs/guide/environment-setup.md)
# ═══════════════════════════════════════════════════════════════════════════

# ── Environment Profile ──
# dev = Development (relaxed security, detailed logs, Swagger enabled)
# test = Testing/CI (in-memory services, mocked email)
# prod = Production (strict security, no Swagger, requires HTTPS)
SPRING_PROFILES_ACTIVE=dev

# ── Database (PostgreSQL) ──
# Dev: Uses docker-compose (port 5433 to avoid conflicts)
# Prod: Use managed database (RDS, Cloud SQL, etc.)
DATABASE_URL=jdbc:postgresql://localhost:5433/fortyeightid
DATABASE_USERNAME=fortyeightid
DATABASE_PASSWORD=fortyeightid
DATABASE_NAME=fortyeightid
DATABASE_HOST_PORT=5433

# ── Redis (Session & Rate Limiting) ──
# Dev: Uses docker-compose
# Prod: Use managed Redis (ElastiCache, Cloud Memorystore, etc.)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Email Service ──
# Dev: Use Mailpit (docker compose up -d mailpit)
# Prod: Use real SMTP (Gmail, SendGrid, AWS SES, etc.)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@48id.local

# Frontend URLs (for email links)
# Dev: Local frontend
# Prod: Your production domain
MAIL_LOGIN_URL=http://localhost:3000/login
MAIL_ACTIVATION_URL=http://localhost:3000/activate-account
MAIL_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ── Mailpit (Development Email Testing) ──
# Web UI port for Mailpit interface
MAILPIT_UI_PORT=8025

# ── JWT Configuration ──
# Issuer should match your backend URL
# Dev: http://localhost:8080
# Prod: https://id.yourdomain.com
JWT_ISSUER=http://localhost:8080
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=86400

# RSA Keys for JWT signing
# Dev: Use provided keys in src/main/resources/keys/
# Prod: Generate new keys and store securely (see docs)
JWT_RSA_PUBLIC_KEY=classpath:keys/public.pem
JWT_RSA_PRIVATE_KEY=classpath:keys/private.pem

# ── CORS (Cross-Origin Resource Sharing) ──
# Dev: Allow localhost frontend
# Prod: Set to your frontend domain(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Server Configuration ──
SERVER_PORT=8080
API_PREFIX=/api/v1

# ── API Documentation (Swagger) ──
# Dev/Test: true (access at http://localhost:8080/swagger-ui.html)
# Prod: false (disable in production)
SPRINGDOC_SWAGGER_ENABLED=true
OPENAPI_SERVERS=http://localhost:8080
