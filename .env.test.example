# ═══════════════════════════════════════════════════════════════════════════
# 48ID Test Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# This configuration is used for integration tests and CI/CD pipelines
# Testcontainers will automatically provision PostgreSQL and Redis
# ═══════════════════════════════════════════════════════════════════════════

# ── Spring Profile ──
SPRING_PROFILES_ACTIVE=test

# ── Database (PostgreSQL) ──
# Testcontainers will override these with dynamic values
DATABASE_URL=jdbc:postgresql://localhost:5432/fortyeightid_test
DATABASE_USERNAME=test
DATABASE_PASSWORD=test

# ── Redis ──
# Testcontainers will override these with dynamic values
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Mail (Test - No-op) ──
# Tests use mock email service
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@test.48id.local
MAIL_LOGIN_URL=http://localhost:3000/login
MAIL_ACTIVATION_URL=http://localhost:3000/activate-account
MAIL_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ── JWT / Security ──
JWT_ISSUER=http://localhost:8080
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=86400
JWT_RSA_PUBLIC_KEY=classpath:keys/public.pem
JWT_RSA_PRIVATE_KEY=classpath:keys/private.pem

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Server ──
SERVER_PORT=8080
API_PREFIX=/api/v1

# ── OpenAPI / Swagger ──
SPRINGDOC_SWAGGER_ENABLED=false
OPENAPI_SERVERS=http://localhost:8080

# ── Rate Limiting (Test - Disabled) ──
# Tests should not be rate limited
RATE_LIMIT_LOGIN_ATTEMPTS=1000
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_FORGOT_PASSWORD_ATTEMPTS=1000
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=60
RATE_LIMIT_GLOBAL_PER_IP=10000
