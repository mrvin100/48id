# ═══════════════════════════════════════════════════════════════════════════
# 48ID Development Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env for local development
# Usage: cp .env.dev.example .env
# ═══════════════════════════════════════════════════════════════════════════

# ── Spring Profile ──
# Options: dev, test, prod
SPRING_PROFILES_ACTIVE=dev

# ── Database (PostgreSQL) ──
# Note: docker-compose maps PostgreSQL to host port 5433 to avoid conflicts
# with local PostgreSQL installations
DATABASE_URL=jdbc:postgresql://localhost:5433/fortyeightid
DATABASE_USERNAME=fortyeightid
DATABASE_PASSWORD=fortyeightid

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Mail (Development) ──
# For local dev, use MailHog: docker run -d -p 1025:1025 -p 8025:8025 mailhog/mailhog
# Web UI: http://localhost:8025
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_FROM=no-reply@48id.local
MAIL_LOGIN_URL=http://localhost:3000/login
MAIL_ACTIVATION_URL=http://localhost:3000/activate-account
MAIL_RESET_PASSWORD_URL=http://localhost:3000/reset-password

# ── JWT / Security ──
# For dev, use the included test keys in src/main/resources/keys/
JWT_ISSUER=http://localhost:8080
JWT_ACCESS_TOKEN_EXPIRY=900
JWT_REFRESH_TOKEN_EXPIRY=86400
JWT_RSA_PUBLIC_KEY=classpath:keys/public.pem
JWT_RSA_PRIVATE_KEY=classpath:keys/private.pem

# ── CORS ──
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Server ──
SERVER_PORT=8080
API_PREFIX=/api/v1

# ── OpenAPI / Swagger ──
# Enable Swagger UI in development
SPRINGDOC_SWAGGER_ENABLED=true
OPENAPI_SERVERS=http://localhost:8080

# ── Rate Limiting (Development - Relaxed) ──
# These are optional overrides for development
# RATE_LIMIT_LOGIN_ATTEMPTS=10
# RATE_LIMIT_LOGIN_WINDOW=900
# RATE_LIMIT_FORGOT_PASSWORD_ATTEMPTS=5
# RATE_LIMIT_FORGOT_PASSWORD_WINDOW=3600
# RATE_LIMIT_GLOBAL_PER_IP=200
